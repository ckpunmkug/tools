{
	"manifest_version": 2
	
	,"version": "1"
	,"name": "Tab switcher"
	,"description": "Extension switch tabs when pressed Escape"
	,"icons": {
		"48": "icons/icon-48.png"
	}

	,"browser_specific_settings": {
		"gecko": {
			"id": "tab_switcher@example.com"
			,"strict_min_version": "45.0"
		}
	}
	
	,"background": {
		"scripts": ["background.js"]
	}
	
	,"permissions": [
		"*://*/*"
		,"tabs"
		,"scripting"
	]
}

